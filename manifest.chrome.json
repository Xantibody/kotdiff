{
  "manifest_version": 3,
  "name": "KotDiff",
  "version": "1.6.1",
  "description": "KingOfTime の勤怠画面に実績と期待時間の差分列を追加",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "KotDiff"
  },
  "permissions": ["storage", "contextMenus", "tabs"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.kingoftime.jp/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
